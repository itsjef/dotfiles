# Font
font-family = IosevkaTerm Nerd Font Mono
font-style = Medium
font-feature = -calt
font-feature = -clig
font-feature = -liga
font-size = 12.5

# Theme
theme = Catppuccin Mocha

# macOS
fullscreen = non-native
confirm-close-surface = false
macos-option-as-alt = left
macos-titlebar-style = hidden
quit-after-last-window-closed = true

# Window
window-padding-x = 4
window-padding-y = 4

# Cursor
cursor-style = block
mouse-hide-while-typing = true

# Shell
shell-integration = detect

# Clipboard
copy-on-select = clipboard

# Keybinds
# Line break for Claude Code input (mirrors WezTerm shift+enter binding)
keybind = shift+enter=text:\x1b\r

# CMD+<number> -> select tmux window <number> (paired with user-keys in tmux.conf)
keybind = cmd+zero=text:\x1b[90;0~
keybind = cmd+one=text:\x1b[90;1~
keybind = cmd+two=text:\x1b[90;2~
keybind = cmd+three=text:\x1b[90;3~
keybind = cmd+four=text:\x1b[90;4~
keybind = cmd+five=text:\x1b[90;5~
keybind = cmd+six=text:\x1b[90;6~
keybind = cmd+seven=text:\x1b[90;7~
keybind = cmd+eight=text:\x1b[90;8~
keybind = cmd+nine=text:\x1b[90;9~
